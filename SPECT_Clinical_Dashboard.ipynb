 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# ⚛️ Python -> PHITS Bridge (Dosimetry Pipeline)\n",
    "임상의가 시각적으로 확정한 3D 체적(Target Volume) 데이터와 비균질 방사능 확률 맵을 PHITS 몬테카를로 엔진이 즉시 연산할 수 있는 `[Voxel]` 및 `[Multi Source]` 텍스트 포맷으로 자동 변환합니다."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import os\n",
    "\n",
    "print(\">>> [PHITS Bridge] Exporting Python 3D Arrays to PHITS format...\")\n",
    "\n",
    "def export_to_phits(ct_arr, src_arr, spacing_mm, export_dir='./PHITS_Input'):\n",
    "    os.makedirs(export_dir, exist_ok=True)\n",
    "    \n",
    "    z_dim, y_dim, x_dim = ct_arr.shape\n",
    "    # 물리 스케일: mm 단위를 PHITS의 기본 단위인 cm로 변환\n",
    "    dx, dy, dz = spacing_mm[0]/10.0, spacing_mm[1]/10.0, spacing_mm[2]/10.0\n",
    "    \n",
    "    xmin, xmax = -x_dim*dx/2, x_dim*dx/2\n",
    "    ymin, ymax = -y_dim*dy/2, y_dim*dy/2\n",
    "    zmin, zmax = -z_dim*dz/2, z_dim*dz/2\n",
    "\n",
    "    # ---------------------------------------------------------\n",
    "    # 1. CT Array -> PHITS Material IDs (voxel_mat.txt)\n",
    "    # ---------------------------------------------------------\n",
    "    # 매질 정의: 1=Air, 2=Tissue, 3=Bone\n",
    "    mat_arr = np.ones_like(ct_arr, dtype=int) * 2  # 기본값 Tissue(2)\n",
    "    mat_arr[ct_arr < -700] = 1                     # Air(1)\n",
    "    mat_arr[ct_arr >  300] = 3                     # Bone(3)\n",
    "    \n",
    "    # PHITS [Voxel]은 x -> y -> z 순서로 읽으므로 flatten()을 적용하면 완벽히 매칭됨\n",
    "    np.savetxt(os.path.join(export_dir, 'voxel_mat.txt'), mat_arr.flatten(), fmt='%d')\n",
    "    \n",
    "    with open(os.path.join(export_dir, 'voxel_geom.inp'), 'w') as f:\n",
    "        f.write(\"[ V o x e l ]\\n\")\n",
    "        f.write(f\"  x-type = 2\\n  nx = {x_dim}\\n  xmin = {xmin:.4f}\\n  xmax = {xmax:.4f}\\n\")\n",
    "        f.write(f\"  y-type = 2\\n  ny = {y_dim}\\n  ymin = {ymin:.4f}\\n  ymax = {ymax:.4f}\\n\")\n",
    "        f.write(f\"  z-type = 2\\n  nz = {z_dim}\\n  zmin = {zmin:.4f}\\n  zmax = {zmax:.4f}\\n\")\n",
    "        f.write(f\"  file = voxel_mat.txt\\n\")\n",
    "\n",
    "    # ---------------------------------------------------------\n",
    "    # 2. Source Array -> PHITS Multi-Source (voxel_source.inp)\n",
    "    # ---------------------------------------------------------\n",
    "    # 방사능 활성도(Activity)가 있는 복셀만 추출하여 독립된 Source로 정의\n",
    "    z_idx, y_idx, x_idx = np.nonzero(src_arr)\n",
    "    weights = src_arr[z_idx, y_idx, x_idx]\n",
    "    tot_weight = np.sum(weights)\n",
    "    \n",
    "    with open(os.path.join(export_dir, 'voxel_source.inp'), 'w') as f:\n",
    "        f.write(\"[ S o u r c e ]\\n\")\n",
    "        f.write(f\"  totfact = 1.0\\n\")\n",
    "        f.write(f\"  proj = isotope\\n\")         # ★ PHITS 3.x 내장 동위원소 스펙트럼 엔진\n",
    "        f.write(f\"  nuclide = 131I\\n\")         # I-131 자동 붕괴 모사\n",
    "        f.write(f\"  dir = all\\n\\n\")\n",
    "        \n",
    "        f.write(\"[ M u l t i  S o u r c e ]\\n\")\n",
    "        f.write(f\"  pegs = {len(weights)}\\n\")\n",
    "        \n",
    "        # 각 복셀의 섭취 확률을 가중치(Weight)로 변환\n",
    "        for i in range(len(weights)):\n",
    "            f.write(f\"  wgt({i+1}) = {weights[i]/tot_weight:.6e}\\n\")\n",
    "        f.write(\"\\n\")\n",
    "        \n",
    "        # 각 복셀의 물리적 3D 좌표 부여\n",
    "        for i in range(len(weights)):\n",
    "            x0 = xmin + x_idx[i]*dx; x1 = x0 + dx\n",
    "            y0 = ymin + y_idx[i]*dy; y1 = y0 + dy\n",
    "            z0 = zmin + z_idx[i]*dz; z1 = z0 + dz\n",
    "            \n",
    "            f.write(f\"  <source> = {i+1}\\n\")\n",
    "            f.write(f\"    s-type = 2\\n\")             # 직육면체 볼륨 선원\n",
    "            f.write(f\"    x0 = {x0:.4f}\\n    x1 = {x1:.4f}\\n\")\n",
    "            f.write(f\"    y0 = {y0:.4f}\\n    y1 = {y1:.4f}\\n\")\n",
    "            f.write(f\"    z0 = {z0:.4f}\\n    z1 = {z1:.4f}\\n\\n\")\n",
    "\n",
    "    # 3. Tally Mesh Grid 공유 설정\n",
    "    with open(os.path.join(export_dir, 'tally_grid.inp'), 'w') as f:\n",
    "        f.write(f\"  x-type = 2\\n  nx = {x_dim}\\n  xmin = {xmin:.4f}\\n  xmax = {xmax:.4f}\\n\")\n",
    "        f.write(f\"  y-type = 2\\n  ny = {y_dim}\\n  ymin = {ymin:.4f}\\n  ymax = {ymax:.4f}\\n\")\n",
    "        f.write(f\"  z-type = 2\\n  nz = {z_dim}\\n  zmin = {zmin:.4f}\\n  zmax = {zmax:.4f}\\n\")\n",
    "\n",
    "    print(f\"✅ PHITS Inputs (Geometry, Source, Tally Grid) successfully generated in: {export_dir}\")\n",
    "\n",
